{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": [
      "@types/node",
      "@types/react-dom",
      "@types/react"
    ],
    "skipLibCheck": true,
    "noImplicitAny": false,
    "moduleResolution": "nodenext",
    "noCheck": false,
    "esModuleInterop": true,
    "lib": [
      "dom",
      "es2015"
    ],
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["node_modules/"]
}